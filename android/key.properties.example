# 复制本文件为 android/key.properties 并填写（key.properties 已在 .gitignore 中，勿提交）。
# 先用 keytool 生成 keystore，例如：
#   cd android
#   keytool -genkeypair -v -storetype PKCS12 -keystore release-keystore.jks \
#     -alias travel_release -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile 为相对于 android/ 目录的路径。

storePassword=你的仓库密码
keyPassword=你的密钥密码
keyAlias=travel_release
storeFile=release-keystore.jks
